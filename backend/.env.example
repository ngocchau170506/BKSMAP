# ========================
# BKMAP Backend — ENV EXAMPLE
# Copy file này thành .env và điền giá trị thực tế
# KHÔNG commit file .env vào git
# ========================

# --- DATABASE ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

# --- SERVER ---
PORT=3000
NODE_ENV=development   # development | production

# --- JWT SECRETS (tối thiểu 64 ký tự random) ---
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_JWT_SECRET=
REFRESH_JWT_SECRET=
ACCESS_TOKEN_EXPIRES=1d
REFRESH_TOKEN_EXPIRES=7d

# --- SMTP (Gmail App Password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password

# --- URLS ---
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
# Nhiều domain: http://localhost:5173,https://bkmap.vercel.app
CORS_ORIGINS=http://localhost:5173

# --- ENCRYPTION KEY (đúng 32 bytes hex = 64 ký tự) ---
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- SUPABASE ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_ANON_KEY=sb_publishable_...