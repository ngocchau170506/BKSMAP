generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// Bảng tài khoản người dùng (Thành viên CLB / Admin)
model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(50)
  password_hash String   @db.VarChar(255)
  username      String?  @db.VarChar(100)
  avatar        String?  @db.Text
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Mối quan hệ: Một user có thể tạo nhiều phòng trọ
  rooms_created Room[]   @relation("UserToRoom")
}

// Bảng thông tin Chủ trọ
model Owner {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @db.VarChar(100)
  phone_number String   @db.VarChar(20)

  // Mối quan hệ: Một chủ trọ có thể sở hữu nhiều phòng trọ
  rooms        Room[]
}

// Bảng thông tin Phòng trọ chính
model Room {
  id                String     @id @default(uuid()) @db.Uuid
  title             String     @db.VarChar(255) // Tiêu đề bài đăng
  address           String     @db.Text        // Địa chỉ chi tiết
  latitude          Decimal    @db.Decimal(10, 8) // Vĩ độ bản đồ
  longitude         Decimal    @db.Decimal(11, 8) // Kinh độ bản đồ
  distance_to_bk    Decimal?   @db.Decimal(5, 2)  // Khoảng cách tới trường Bách Khoa
  
  price             Int        // Giá thuê (đơn vị: VNĐ)
  area              Decimal    @db.Decimal(5, 2)  // Diện tích m2
  electricity_price Int?       // Giá điện
  water_price       Int?       // Giá nước
  
  shared_owner      Boolean    @default(false)    // Ở chung chủ hay không (true/false)
  curfew            String?    @db.VarChar(100)   // Giờ giới nghiêm (nếu có)
  description       String?    @db.Text           // Mô tả chi tiết thêm

  created_by        String     @db.Uuid // ID người tạo bài (FK)
  owner_id          String     @db.Uuid // ID chủ trọ (FK)
  created_at        DateTime   @default(now())
  updated_at        DateTime @updatedAt

  // Khai báo liên kết các mối quan hệ (Relations)
  creator           User           @relation("UserToRoom", fields: [created_by], references: [id])
  owner             Owner          @relation(fields: [owner_id], references: [id])
  images            RoomImage[]
  features          RoomFeature[]  // Liên kết sang bảng trung gian tiện ích
}

// Bảng danh mục Tiện ích / Nội thất (Wifi, Điều hòa, Gác lửng, Máy giặt...)
model Feature {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique @db.VarChar(100) // Tên tiện ích
  icon  String? @db.VarChar(50)         // Tên icon để frontend hiển thị

  // Mối quan hệ N-N với Room thông qua bảng trung gian
  rooms RoomFeature[]
}

// Bảng trung gian N-N liên kết giữa Phòng trọ và Tiện ích
model RoomFeature {
  room_id    String @db.Uuid
  feature_id String @db.Uuid

  room       Room    @relation(fields: [room_id], references: [id], onDelete: Cascade)
  feature    Feature @relation(fields: [feature_id], references: [id], onDelete: Cascade)

  @@id([room_id, feature_id]) // Khóa chính tổ hợp
}

// Bảng lưu danh sách ảnh của phòng trọ
model RoomImage {
  id            String   @id @default(uuid()) @db.Uuid
  room_id       String   @db.Uuid
  image_url     String   @db.Text
  display_order Int      @default(0) // Thứ tự hiển thị (ảnh nào hiện trước)
  created_at    DateTime @default(now())

  room          Room     @relation(fields: [room_id], references: [id], onDelete: Cascade)
}